{
  "name": "focus-os",
  "version": "2.0.0",
  "description": "Local-first focus command center — timer, capture, notes, email, todo, calendar",
  "main": "dist/main/main/index.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "postinstall": "echo 'no native rebuild needed'",
    "dist:mac": "npm run build && electron-builder --mac --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:renderer": "vite"
  },
  "author": "Sunny Soni",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/imap": "^0.8.40",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.5.10",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.sunnysoni.focusos",
    "productName": "Focus OS",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": null
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main/index.js"
    }
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@tiptap/core": "^2.6.0",
    "@tiptap/extension-underline": "^2.6.0",
    "@tiptap/react": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "@xenova/transformers": "^2.17.2",
    "active-win": "^7.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^7.0.3",
    "imap": "^0.8.19",
    "lucide-react": "^1.11.0",
    "mailparser": "^3.7.1",
    "tailwind-merge": "^3.5.0",
    "uiohook-napi": "^1.5.5",
    "uuid": "^9.0.1"
  }
}
